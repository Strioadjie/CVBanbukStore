# Database
DATABASE_URL="file:./dev.db"

# NextAuth
NEXTAUTH_SECRET="ganti-dengan-random-string-minimal-32-karakter-panjang"
NEXTAUTH_URL="http://localhost:3000"

# Web3 Configuration
# Isi setelah deploy smart contract
NEXT_PUBLIC_CONTRACT_ADDRESS=""

# Infura RPC URL (daftar gratis di https://infura.io)
NEXT_PUBLIC_RPC_URL="https://sepolia.infura.io/v3/YOUR_INFURA_API_KEY"

# Private Key wallet untuk deploy contract
# JANGAN SHARE KE SIAPAPUN!
PRIVATE_KEY=""

# Midtrans Payment Gateway
# Daftar di https://dashboard.midtrans.com
MIDTRANS_SERVER_KEY="your-server-key"
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY="your-client-key"

# WhatsApp
# Format: 628123456789 (tanpa + dan spasi)
NEXT_PUBLIC_WHATSAPP_NUMBER="628123456789"

# ===================================
# CARA MENDAPATKAN NILAI-NILAI DI ATAS:
# ===================================

# 1. NEXTAUTH_SECRET
#    Generate dengan command:
#    node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"

# 2. NEXT_PUBLIC_RPC_URL
#    - Daftar di https://infura.io (gratis)
#    - Buat project baru
#    - Pilih network: Sepolia
#    - Copy API Key
#    - Format: https://sepolia.infura.io/v3/YOUR_API_KEY

# 3. PRIVATE_KEY
#    - Buka MetaMask
#    - Klik 3 titik > Account Details
#    - Export Private Key
#    - Masukkan password
#    - Copy private key (tanpa 0x)
#    ⚠️ JANGAN SHARE PRIVATE KEY!

# 4. NEXT_PUBLIC_CONTRACT_ADDRESS
#    - Deploy contract dulu dengan: npx hardhat run scripts/deploy.js --network sepolia
#    - Copy contract address dari output
#    - Paste di sini

# 5. NEXT_PUBLIC_WHATSAPP_NUMBER
#    - Ganti dengan nomor WhatsApp bisnis Anda
#    - Format: 628123456789 (62 = kode Indonesia)
